APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database and other examples omitted for brevity...

# ICD API configuration
# Set the API base URL (e.g. https://api.example.com) and token URL for
# client_credentials token exchange. If `BHCIS_ICD_API_ENABLED` is true and
# `BHCIS_ICD_API_BASE_URL` + `BHCIS_ICD_API_TOKEN_URL` are set, the app will
# query the remote ICD API for diagnosis lookups. Otherwise it will use the
# local `diagnosis_lookup` table.
BHCIS_ICD_API_ENABLED=true
BHCIS_ICD_API_BASE_URL=
BHCIS_ICD_API_TOKEN_URL=
BHCIS_ICD_API_SEARCH_PATH=/search

# Credentials provided (change if needed)
BHCIS_ICD_API_CLIENT_ID=0a50f6d2-b464-4ecb-a4cb-77f7d5b756ac_a49c6ac3-7182-46c2-bcb9-5a8833902720
BHCIS_ICD_API_CLIENT_SECRET=3tk9e52/a8sjQMxVYHwcdpEnXQaLQbTUfgrKCosJtws=
